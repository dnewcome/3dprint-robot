<?xml version="1.0"?>
<!-- ============================================================
     arm_trunk.urdf — 5-DOF micro-cycloidal arm (integrated arm sections).

     Every joint is the 20:1 Micro Cycloidal EXCEPT the base slew. The long arm
     SECTIONS are the real printed parts (build123d arm_section.py -> exported to
     meshes/arm_long.stl): each integrates the rotating HOUSING (upstream joint
     output) at one end and the NEMA17 motor PLATE (downstream motor mount) at
     the other -- so the actuators "contain the end pieces" and the section mesh
     IS the link. A joint forms in the gap between two sections.

     Section mesh frame: housing axis along Y at the section ORIGIN; the blade
     runs +X to the base at (X=0.150, Y=-0.0046). Pitch joints are about Y; the
     blade is tall in Z (resists gravity sag).

     The base (slew->shoulder) and wrist (pitch->tool-roll) are 90-degree
     sections that aren't designed yet -> simple stand-in geometry for now.
     Generate meshes/arm_long.stl (gitignored, vendor-derived):
       python sim/gen_meshes.py   (needs build123d + your purchased STEP)
     ============================================================ -->
<robot name="micro_arm">

  <mujoco>
    <compiler balanceinertia="true" discardvisual="false" fusestatic="false"
              meshdir="meshes"/>
  </mujoco>

  <material name="motor"><color rgba="0.13 0.13 0.15 1"/></material>
  <material name="link"> <color rgba="0.78 0.78 0.80 1"/></material>
  <material name="tool"> <color rgba="0.27 0.51 0.71 1"/></material>

  <!-- ===== base pedestal + slew motor (the one non-micro drive) ===== -->
  <link name="base_link">
    <visual><origin xyz="0 0 0.03"/>
      <geometry><cylinder radius="0.045" length="0.06"/></geometry>
      <material name="motor"/></visual>
    <inertial><origin xyz="0 0 0.03"/><mass value="1.0"/>
      <inertia ixx="3e-3" iyy="3e-3" izz="3e-3" ixy="0" ixz="0" iyz="0"/></inertial>
  </link>

  <!-- ===== J1 base slew (Z) ===== -->
  <joint name="j1_yaw" type="revolute">
    <parent link="base_link"/><child link="mast_link"/>
    <origin xyz="0 0 0.065"/><axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="20" velocity="3.0"/>
    <dynamics damping="0.05"/>
  </joint>

  <!-- ===== base 90-deg section: slew output -> shoulder motor (STAND-IN) ===== -->
  <link name="mast_link">
    <visual><origin xyz="0 0 0.025"/>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="motor"/></visual>
    <inertial><origin xyz="0 0 0.025"/><mass value="0.3"/>
      <inertia ixx="5e-4" iyy="5e-4" izz="5e-4" ixy="0" ixz="0" iyz="0"/></inertial>
  </link>

  <!-- ===== J2 shoulder pitch (Y) ===== -->
  <joint name="j2_shoulder" type="revolute">
    <parent link="mast_link"/><child link="upper_arm_link"/>
    <origin xyz="0 0 0.055"/><axis xyz="0 1 0"/>
    <limit lower="-1.92" upper="1.92" effort="18" velocity="3.0"/>
    <dynamics damping="0.05"/>
  </joint>

  <!-- ===== upper arm SECTION: housing(shoulder out) --150mm--> base(elbow motor) ===== -->
  <link name="upper_arm_link">
    <visual><geometry><mesh filename="arm_long.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="link"/></visual>
    <inertial><origin xyz="0.075 -0.002 0"/><mass value="0.18"/>
      <inertia ixx="6e-5" iyy="4e-4" izz="4e-4" ixy="0" ixz="0" iyz="0"/></inertial>
  </link>

  <!-- ===== J3 elbow pitch (Y) at the upper-arm base ===== -->
  <joint name="j3_elbow" type="revolute">
    <parent link="upper_arm_link"/><child link="forearm_link"/>
    <origin xyz="0.150 -0.0046 0"/><axis xyz="0 1 0"/>
    <limit lower="-2.62" upper="2.62" effort="15" velocity="3.0"/>
    <dynamics damping="0.05"/>
  </joint>

  <!-- ===== forearm SECTION: housing(elbow out) --150mm--> base(wrist motor) ===== -->
  <link name="forearm_link">
    <visual><geometry><mesh filename="arm_long.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="link"/></visual>
    <inertial><origin xyz="0.075 -0.002 0"/><mass value="0.18"/>
      <inertia ixx="6e-5" iyy="4e-4" izz="4e-4" ixy="0" ixz="0" iyz="0"/></inertial>
  </link>

  <!-- ===== J4 wrist pitch (Y) ===== -->
  <joint name="j4_wrist_pitch" type="revolute">
    <parent link="forearm_link"/><child link="wrist_link"/>
    <origin xyz="0.150 -0.0046 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.92" upper="1.92" effort="6" velocity="3.0"/>
    <dynamics damping="0.03"/>
  </joint>

  <!-- ===== wrist 90-deg section (STAND-IN) ===== -->
  <link name="wrist_link">
    <visual><origin xyz="0.025 0 0"/>
      <geometry><box size="0.05 0.042 0.042"/></geometry>
      <material name="motor"/></visual>
    <inertial><origin xyz="0.025 0 0"/><mass value="0.1"/>
      <inertia ixx="3e-4" iyy="3e-4" izz="3e-4" ixy="0" ixz="0" iyz="0"/></inertial>
  </link>

  <!-- ===== J5 tool roll (about the tool axis, X) ===== -->
  <joint name="j5_tool_roll" type="revolute">
    <parent link="wrist_link"/><child link="tool_link"/>
    <origin xyz="0.05 0 0"/><axis xyz="1 0 0"/>
    <limit lower="-3.1416" upper="3.1416" effort="4" velocity="3.0"/>
    <dynamics damping="0.03"/>
  </joint>

  <link name="tool_link">
    <visual><origin xyz="0.02 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.02" length="0.006"/></geometry>
      <material name="link"/></visual>
    <visual><origin xyz="0.05 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.006" length="0.06"/></geometry>
      <material name="tool"/></visual>
    <inertial><origin xyz="0.03 0 0"/><mass value="0.06"/>
      <inertia ixx="1e-4" iyy="1e-4" izz="5e-5" ixy="0" ixz="0" iyz="0"/></inertial>
  </link>

  <!-- ===== TCP ===== -->
  <joint name="tcp_fixed" type="fixed">
    <parent link="tool_link"/><child link="tcp_link"/>
    <origin xyz="0.08 0 0"/>
  </joint>
  <link name="tcp_link">
    <inertial><mass value="0.001"/>
      <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0"/></inertial>
  </link>

  <!-- ===== transmissions: 20:1 micro cyclo at every joint (ros2_control reads
       these; MuJoCo ignores them and gets actuators from the sim scripts). ===== -->
  <transmission name="tr_j1"><type>transmission_interface/SimpleTransmission</type>
    <joint name="j1_yaw"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface></joint>
    <actuator name="j1_motor"><mechanicalReduction>20</mechanicalReduction></actuator></transmission>
  <transmission name="tr_j2"><type>transmission_interface/SimpleTransmission</type>
    <joint name="j2_shoulder"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface></joint>
    <actuator name="j2_motor"><mechanicalReduction>20</mechanicalReduction></actuator></transmission>
  <transmission name="tr_j3"><type>transmission_interface/SimpleTransmission</type>
    <joint name="j3_elbow"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface></joint>
    <actuator name="j3_motor"><mechanicalReduction>20</mechanicalReduction></actuator></transmission>
  <transmission name="tr_j4"><type>transmission_interface/SimpleTransmission</type>
    <joint name="j4_wrist_pitch"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface></joint>
    <actuator name="j4_motor"><mechanicalReduction>20</mechanicalReduction></actuator></transmission>
  <transmission name="tr_j5"><type>transmission_interface/SimpleTransmission</type>
    <joint name="j5_tool_roll"><hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface></joint>
    <actuator name="j5_motor"><mechanicalReduction>20</mechanicalReduction></actuator></transmission>

</robot>
